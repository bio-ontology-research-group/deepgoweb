# Copy to .env and adjust. Consumed by docker-compose.yml / settings/docker.py.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=*

# --- Postgres ---
POSTGRES_PASSWORD=postgres

# --- assets ---
# Legacy DeepGOPlus release to fetch into /opt-data/extracted/<ver>/
DEEPGO_RELEASE=1.0.18
# Set to 0 once the asset volumes are populated to skip the download check on boot.
DOWNLOAD_ASSETS=1
# Asset mirror base URL.
DATA_BASE=https://bio2vec.net/data

# --- ports ---
WEB_PORT=8000
FUSEKI_PORT=3330

# --- prediction worker ---
DGPP_THREADS=8
CELERY_CONCURRENCY=2
